{
  "name": "gl-style-builder",
  "version": "1.0.0",
  "description": "Using GeostatsLayer or RasterInfo input, along with optional AiDataAnalystNotes or a target visualization type, creates a mapbox-gl-style that can be used with SeaSketch's graphical cartography tool",
  "keywords": [
    "SeaSketch"
  ],
  "author": "Chad Burt <chad@underbluewaters.net>",
  "homepage": "https://github.com/seasketch/next#readme",
  "license": "BSD-3-Clause",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "directories": {
    "lib": "lib",
    "test": "__tests__"
  },
  "files": [
    "dist/lib"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seasketch/next.git"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "watch": "tsc -w"
  },
  "bugs": {
    "url": "https://github.com/seasketch/next/issues"
  },
  "dependencies": {
    "@seasketch/geostats-types": "^1.0.0",
    "@types/mapbox-gl": "3.1.0",
    "ai-data-analyst": "^1.0.0",
    "d3-scale-chromatic": "2.0.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
