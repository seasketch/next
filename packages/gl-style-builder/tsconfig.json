{
  "compilerOptions": {
    "incremental": true,
    "composite": true,
    "tsBuildInfoFile": "./.tsbuildinfo",
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["lib/index.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.spec.ts"],
  "references": [
    { "path": "../geostats-types" },
    { "path": "../ai-data-analyst" }
  ]
}
